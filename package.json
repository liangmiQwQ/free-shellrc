{
  "name": "free-shellrc",
  "version": "0.3.0",
  "description": "Cross-platform shell profile integration.",
  "homepage": "https://github.com/liangmiQwQ/free-shellrc#readme",
  "bugs": {
    "url": "https://github.com/liangmiQwQ/free-shellrc/issues"
  },
  "license": "MIT",
  "author": "Liang Mi <hi@liangmi.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liangmiQwQ/free-shellrc.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp run cpack",
    "check": "vp run ccheck",
    "prepare": "vp config",
    "prepublishOnly": "vp run build",
    "release": "bumpp",
    "test": "vp run ctest run"
  },
  "dependencies": {
    "which-command": "^0.1.0"
  },
  "devDependencies": {
    "@liangmi/vp-config": "^0.3.0",
    "@types/node": "^26.1.1",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "bumpp": "^11.1.0",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.4",
    "vitest": "^4.1.10"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.11.0",
      "onFail": "download"
    }
  }
}
